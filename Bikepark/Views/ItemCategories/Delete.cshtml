@model Bikepark.Models.ItemCategory

@{
    ViewData["Title"] = "Delete Items Category";
    ViewData["menu"] = "storage";
    Layout = "_MainLayout";
    int typesCount = ViewBag.ItemTypesCount;
}

<h3>Delete Items Category</h3>

<h4>Do you really want to delete this Items Category?</h4>
<div>
    
<div class="col-md-4">  
    @if(typesCount==0){
        <h5>There is no Item Types in this Category.</h5>
    }
    else
    {
        <h5 style="display:inline">The amount of Bikes or Accessories in this Category:</h5>  <h3 style="display:inline">@typesCount</h3>
        <p><a target="_blank" rel="noopener noreferrer" href="/Storage/InCategory/?id=@Model.ItemCategoryID">View all in a new tab?</a></p>
        <p>If you delete a category, the Items will remain in the storage, but without an assigned category.</p>
    }
</div>

        <hr />
    
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ItemCategoryName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ItemCategoryName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Accessories)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Accessories)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="ItemCategoryID" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        <input type="submit" value="Delete" class="btn btn-danger" />
    </form>
</div>
