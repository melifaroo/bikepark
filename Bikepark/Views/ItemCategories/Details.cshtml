@model Bikepark.Models.ItemCategory

@{
    ViewData["Title"] = "Item Category Details";
    ViewData["menu"] = "storage";
    Layout = "_MainLayout";
}

<h3>Item Category Details</h3>

<div>
    <h4>Item Category</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ItemCategoryName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ItemCategoryName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Accessories)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Accessories)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
    <a asp-action="Edit" asp-route-id="@Model?.ItemCategoryID">Change</a>     
</div>
