@model Bikepark.Models.PricingCategory

@{
    ViewData["Title"] = "Pricing Category Details";
    ViewData["menu"] = "pricing-categories";
    Layout = "_MainLayout";
}

<h3>Pricing Category Details</h3>

<div>
    <h4>Pricing Category</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PricingCategoryName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PricingCategoryName)
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
    <a asp-action="Edit" asp-route-id="@Model?.PricingCategoryID">Change</a> 
</div>
