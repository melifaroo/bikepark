@model Bikepark.Models.Pricing

@{
    ViewData["Title"] = "Change Billing Plan";
    ViewData["menu"] = "pricing";
    Layout = "_MainLayout";

    var hasRecords = ViewBag.HasRecords;
    string archival = Model.Archival ? "(archival)" : "";
}

<div class="col-md-6">  
@if (Model.PricingID != null)
{
    <h3>Change Billing Plan</h3>
    <h4>Billing Plan #@Model.PricingID @archival</h4>
}
else
{
    <h3>Add</h3>
    <h4>Billing Plan</h4>    
}
</div>  
<hr />
<div class="container-sm">  
    <form asp-controller="Pricing">
        <div class="row">
            <div class="col-md-4">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="PricingID" />
                <div class="form-group">
                    <label asp-for="PricingName" class="control-label"></label>
                    <input asp-for="PricingName" class="form-control" required/>
                    <span asp-validation-for="PricingName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PricingCategoryID" class="control-label"></label>
                    <select asp-for="PricingCategoryID" class="form-control" asp-items="ViewBag.PricingCategoryID">
                        <option value="">Not specified</option></select>
                    <span asp-validation-for="PricingCategoryID" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PricingType" class="control-label"></label>
                    <select asp-for="PricingType" asp-items="Html.GetEnumSelectList<PricingType>()" class="form-control" required></select>
                    <span asp-validation-for="PricingType" class="text-danger"></span>
                </div>
                <div class="form-group" id="daysofweek">
                    <label asp-for="DaysOfWeek" class="control-label"></label>
                    <partial name="_DaysOfWeekInput" model="@Model.DaysOfWeek" />
                </div>
                <div class="form-group form-check" id="holiday">
                    <label class="form-check-label">
                        <input class="form-check-input" asp-for="IsHoliday" /> @Html.DisplayNameFor(model => model.IsHoliday)
                    </label>
                </div>
                <div class="form-group form-check" id="reduced">
                    <label class="form-check-label">
                        <input class="form-check-input" asp-for="IsReduced" /> @Html.DisplayNameFor(model => model.IsReduced)
                    </label>
                </div>
                <div class="form-group" id="duration">
                    <label asp-for="MinDuration" class="control-label"></label>
                    <input asp-for="MinDuration" class="form-control" />
                    <span asp-validation-for="MinDuration" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Price" class="control-label"></label>
                    <input asp-for="Price" class="form-control" required/>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            </div>
        </div>

        
        <div class="flex-row justify-content-start">
            <div class="row row-cols-4 col-md-8 ">
                <div class="form-group col-md-2 ">  
                    <a asp-action="Index" class="btn btn-secondary col-md-12">Cancel</a>
                </div>
                @if (Model.PricingID != null)
                {
                    <div class="form-group col-md-2 ">
                        <button type="submit"  asp-action="Edit" class="btn btn-dark col-md-12">Change</button> 
                    </div>
                    @if (hasRecords)
                    {
                        <div class="form-group col-md-2 ">
                            <button type="submit"  asp-action="Replace" class="btn btn-primary col-md-12"  title="Replace the Billing Plan; the previous Plan will be archived.">Replace</button> 
                        </div>
                    }
                    else
                    {
                        <div class="col-md-2 ">
                        </div>                        
                    }
                    <div class="form-group col-md-2 ">
                        <button type="submit"  asp-action="Create"  class="btn btn-info col-md-12" title="Copy and create a new Billing Plan.">Copy</button> 
                    </div>
                }
                else
                {
                    <div class="form-group col-md-2 ">
                        <button type="submit"  asp-action="Create" class="btn btn-primary col-md-12">Create</button> 
                    </div>
                    <div class="col-md-2 ">
                    </div>
                    <div class="col-md-2 ">
                    </div>
                }
            </div>
        </div>
    </form>
</div>
<div class="col-md-6">  
@if (Model.PricingID != null)
{
    @if (hasRecords)
    { 
        <h5 style="display:inline">The log contains records regarding the rental of Items billed within this Plan.</h5>  
        <p><a target="_blank" rel="noopener noreferrer" href="/Log/WithPricing/?id=@Model.PricingID">View the log excerpt in a new tab?</a></p>
        <p>If you CHANGE it, this affect all existing log Records.</p>
        <p>If you REPLACE it, the old Billing Plan will be archived (and will appear in the existing log Records), and a new one will be created.</p>
        <p>If you COPY it, the original Billing Plan will remain unchanged, but a new one will be created based on it.</p>
    } 
}
</div>



@section Scripts {          
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/pricing-main.js"></script> 

}